// Copy to Secrets.xcconfig and fill in. Secrets.xcconfig is gitignored.
// After editing: `xcodegen generate` to pick up the build setting, then rebuild.

// Spotify — register an app at https://developer.spotify.com/dashboard
// Add `studiojoe-musicplayer://spotify-callback` as a Redirect URI under the app's Settings.
SPOTIFY_CLIENT_ID = your-spotify-client-id-here
